# Changes to this file will require a container rebuild as it is sourced from /etc/profile.d/defaultrc.sh

# Agent CLI homes in gitignored tmp/ (survive rebuilds; keep out of project config).
export WORKSPACE_ROOT=/workspaces/astralbeam
export CODEX_HOME=/workspaces/astralbeam/tmp/.codex
export CURSOR_CONFIG_DIR=/workspaces/astralbeam/tmp/.cursor
export CLAUDE_CONFIG_DIR=/workspaces/astralbeam/tmp/.claude
export OPENCODE_CONFIG_DIR=/workspaces/astralbeam/tmp/.opencode

# Persist shell history in the gitignored, host-mounted workspace tmp directory.
export HISTFILE=/workspaces/astralbeam/tmp/.zsh_history
export HISTSIZE=10000
export SAVEHIST=10000

export TANSTACK_CLI_TELEMETRY_DISABLED=1

# Database and Valkey URLs are set from container environment variables.
export DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
export VALKEY_URL=valkey://${VALKEY_HOST}:${VALKEY_PORT}
